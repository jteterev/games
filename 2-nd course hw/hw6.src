//задание 2

function filterStringsByStart(array, searchString) {
    const result = [];
    const lowerSearchString = searchString.toLowerCase();
    
    for (let i = 0; i < array.length; i++) {
        const currentItem = array[i];
        
        if (currentItem.toLowerCase().startsWith(lowerSearchString)) {
            result.push(currentItem);
        }
    }
    
    return result;
}

const fruits = ['Apple', 'Banana', 'apricot', 'Grape', 'Avocado', 'orange'];
const filtered = filterStringsByStart(fruits, 'ap');

console.log(filtered);

