//задание 5

function getRandomNumber() {
    const randomNumber = Math.floor(Math.random() * 10) + 1;
    console.log(randomNumber);
}

//задание 6

function generateRandomArray(number) {

    if (number <= 0) {
        console.error('Число должно быть положительным');
        return [];
    }
    
    const arrayLength = Math.floor(number / 2);
    
    const result = [];
    
    for (let i = 0; i < arrayLength; i++) {
        const randomNum = Math.floor(Math.random() * (number + 1));
        result.push(randomNum);
    }
    
    return result;
}

console.log(generateRandomArray(10));

//задание 7

function getRandomInRange(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
}

console.log(getRandomInRange(1, 10));
console.log(getRandomInRange(5, 15));
console.log(getRandomInRange(100, 200));

